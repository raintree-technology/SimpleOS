{
  "name": "simpleos-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "lsof -ti:3500 | xargs kill -9 2>/dev/null || true; next dev --turbopack -p 3500",
    "build:os": "cd .. && make && mkdir -p web/public/os && cp simpleos.iso web/public/os/simpleos.iso",
    "build": "next build",
    "start": "next start -p 3500",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "^16.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.16",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
